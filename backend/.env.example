PORT=5000
MONGODB_URI=mongodb://localhost:27017/artrise
JWT_SECRET=your-user-secret
JWT_ADMIN_SECRET=your-admin-secret
NODE_ENV=development

# Cloudflare R2 Storage (required for image uploads)
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-bucket.your-account-id.r2.dev

# Backward compatible (optional):
# DB_URL=mongodb://localhost:27017/artrise
